<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.javaclaw</groupId>
    <artifactId>javaclaw</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>JavaClaw</name>
    <description>基于 JavaFX 和 AgentScope 的智能体桌面聊天应用</description>

    <properties>
        <!-- 编码与 JDK 版本（JDK 25 LTS：虚拟线程无 pinning、Scoped Values 正式版） -->
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>

        <!-- 依赖版本管理 -->
        <!-- JavaFX 24：兼容 JDK 25，原生库支持 macOS aarch64 -->
        <javafx.version>25</javafx.version>
        <agentscope.version>1.0.12</agentscope.version>
        <logback.version>1.4.14</logback.version>
        <angus.mail.version>2.0.3</angus.mail.version>
        <pdfbox.version>3.0.4</pdfbox.version>
        <richtextfx.version>0.11.7</richtextfx.version>
        <commonmark.version>0.24.0</commonmark.version>
    </properties>

    <!--
        AgentScope BOM：统一管理 agentscope-* 全部子模块版本。
        引入 BOM 后，下面声明的 agentscope-* 依赖都无需写 version。
    -->
    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>io.agentscope</groupId>
                <artifactId>agentscope-bom</artifactId>
                <version>${agentscope.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <!--
            AgentScope 全功能包
            包含: OkHttp、Jackson、SLF4J API、Reactor Core 等
            无需单独声明这些传递依赖；版本由 agentscope-bom 统一管理
        -->
        <dependency>
            <groupId>io.agentscope</groupId>
            <artifactId>agentscope</artifactId>
        </dependency>

        <!--
            Quartz 调度器（通过 AgentScope scheduler-quartz 扩展引入 quartz 2.5.2）
            JavaClaw 直接使用底层 org.quartz.Scheduler 接管定时任务调度，
            不使用扩展提供的 QuartzAgentScheduler 封装（其内部建独立 Agent，
            会绕过 JavaClaw 自己的 ChatService 编排栈）。
        -->
        <dependency>
            <groupId>io.agentscope</groupId>
            <artifactId>agentscope-extensions-scheduler-quartz</artifactId>
        </dependency>

        <!-- JavaFX 控件库（UI 组件：Button、TextField、ScrollPane 等） -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- JavaFX WebView（内嵌浏览器，用于 Web 智能体） -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-web</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- JavaFX Swing 桥接（用于 WebView 截图保存） -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-swing</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!--
            Jakarta Mail（邮件收发）
            提供 SMTP 发送和 IMAP 接收能力
        -->
        <dependency>
            <groupId>org.eclipse.angus</groupId>
            <artifactId>angus-mail</artifactId>
            <version>${angus.mail.version}</version>
        </dependency>

        <!--
            Apache PDFBox（PDF 文本提取）
            用于从 PDF 文档中提取文本内容发送给模型
        -->
        <dependency>
            <groupId>org.apache.pdfbox</groupId>
            <artifactId>pdfbox</artifactId>
            <version>${pdfbox.version}</version>
        </dependency>

        <!--
            OpenAI Java SDK（嵌入模型）
            AgentScope 的 OpenAITextEmbedding 依赖此 SDK，需单独引入
        -->
        <dependency>
            <groupId>com.openai</groupId>
            <artifactId>openai-java</artifactId>
            <version>4.28.0</version>
        </dependency>

        <!--
            Anthropic Java SDK（Claude 系列模型）
            AgentScope 的 AnthropicChatModel 依赖此 SDK，需单独引入
        -->
        <dependency>
            <groupId>com.anthropic</groupId>
            <artifactId>anthropic-java-client-okhttp</artifactId>
            <version>2.14.0</version>
        </dependency>

        <!--
            Google GenAI SDK（Gemini 系列模型）
            AgentScope 的 GeminiChatModel 依赖此 SDK，需单独引入
        -->
        <dependency>
            <groupId>com.google.genai</groupId>
            <artifactId>google-genai</artifactId>
            <version>1.28.0</version>
        </dependency>

        <!--
            RichTextFX（富文本编辑/展示）
            提供原生文本选中复制、多行输入、样式化文本等能力
        -->
        <dependency>
            <groupId>org.fxmisc.richtext</groupId>
            <artifactId>richtextfx</artifactId>
            <version>${richtextfx.version}</version>
        </dependency>

        <!--
            CommonMark（Markdown 解析与 HTML 渲染）
            用于聊天气泡中 Markdown 格式内容的渲染展示
        -->
        <dependency>
            <groupId>org.commonmark</groupId>
            <artifactId>commonmark</artifactId>
            <version>${commonmark.version}</version>
        </dependency>
        <dependency>
            <groupId>org.commonmark</groupId>
            <artifactId>commonmark-ext-gfm-tables</artifactId>
            <version>${commonmark.version}</version>
        </dependency>
        <dependency>
            <groupId>org.commonmark</groupId>
            <artifactId>commonmark-ext-gfm-strikethrough</artifactId>
            <version>${commonmark.version}</version>
        </dependency>
        <dependency>
            <groupId>org.commonmark</groupId>
            <artifactId>commonmark-ext-autolink</artifactId>
            <version>${commonmark.version}</version>
        </dependency>

        <!--
            Logback 日志实现
            SLF4J API 已由 AgentScope 传递引入，这里只需要实现层
        -->
        <dependency>
            <groupId>ch.qos.logback</groupId>
            <artifactId>logback-classic</artifactId>
            <version>${logback.version}</version>
        </dependency>

        <!--
            Playwright Java（原生浏览器自动化）
            替代 JavaFX WebView，提供完整的浏览器交互能力：
            无障碍树快照、元素引用、截图标注、Tab管理、Cookie 持久化等
        -->
        <dependency>
            <groupId>com.microsoft.playwright</groupId>
            <artifactId>playwright</artifactId>
            <version>1.52.0</version>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Maven 编译插件：指定 JDK 25 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <release>25</release>
                </configuration>
            </plugin>

            <!--
                JavaFX Maven 插件：用于运行 JavaFX 应用
                使用 Launcher 类作为入口，避免非模块化 JavaFX 的启动问题
                运行命令：mvn javafx:run
            -->
            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>
                <version>0.0.8</version>
                <configuration>
                    <mainClass>com.javaclaw.app.Launcher</mainClass>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
